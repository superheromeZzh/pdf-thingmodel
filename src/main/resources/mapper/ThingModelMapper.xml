<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.pdftm.mapper.ThingModelMapper">

    <resultMap id="ThingModelResult" type="com.example.pdftm.domain.ChunkModel">
        <id     column="chunk_id"   property="chunkId"/>
        <result column="model"      property="thingModel"
                typeHandler="com.example.pdftm.handler.JsonbTypeHandler"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findByChunkId" resultMap="ThingModelResult">
        SELECT * FROM thing_models WHERE chunk_id = #{chunkId} LIMIT 1
    </select>

    <!--
        写入或覆盖：每 chunk 只保留一行。走 PostgreSQL/openGauss 的 ON CONFLICT。
        没有版本/审计/乐观锁——并发写最后写者胜。触发器 trg_set_updated_at 会自动更新 updated_at。
    -->
    <insert id="upsert">
        INSERT INTO thing_models (chunk_id, model)
        VALUES (
            #{chunkId},
            #{model,jdbcType=OTHER,typeHandler=com.example.pdftm.handler.JsonbTypeHandler}
        )
        ON CONFLICT (chunk_id) DO UPDATE SET model = EXCLUDED.model
    </insert>

    <!--
        跨 chunk 反查："找出所有当前物模型里包含某 JSON 片段的"。
        @> 是 PostgreSQL/openGauss 的 jsonb 包含运算符；用 CDATA 避免和 XML 解析冲突。
    -->
    <select id="findContainingFragment" resultMap="ThingModelResult">
        <![CDATA[
        SELECT tm.* FROM thing_models tm
        JOIN document_chunks c ON c.chunk_id = tm.chunk_id
        WHERE c.document_id = #{documentId}
          AND tm.model @> CAST(#{fragmentJson} AS jsonb)
        ]]>
    </select>

</mapper>
